PORT=3001

# Origenes permitidos para CORS (coma-separados)
# Incluye :3001 si sirves invitación+admin con npm start (Express); +5500/8765 si usas Live Server
CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8765,http://localhost:8765

# Token para endpoints admin
ADMIN_TOKEN=cambia-esto-en-produccion
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esto-super-seguro
ADMIN_AUTH_SECRET=cambia-esto-con-32-caracteres-minimo
ADMIN_SESSION_TTL_HOURS=12

# --- Supabase ---
SUPABASE_URL=https://bsjalzucuapmlfuzmnnd.supabase.co
# Public anon key (cliente)
SUPABASE_ANON_KEY=
# Service role key (solo backend)
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token de Supabase (CLI/automatizaciones)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=bsjalzucuapmlfuzmnnd
SUPABASE_SCHEMA=public
SUPABASE_GUESTS_TABLE=guests
SUPABASE_RSVP_TABLE=rsvps
SUPABASE_INVITATIONS_TABLE=invitation_sends
# Una sola URL (no pongas dos dominios separados por coma; si lo haces, el servidor solo usa la primera).
FRONTEND_BASE_URL=http://127.0.0.1:3001
# URL que verán los invitados en WhatsApp (debe ser https:// + dominio público). WhatsApp Web NO convierte en enlace 127.0.0.1 ni localhost.
# En Vercel/producción: https://tu-proyecto.vercel.app (o tu dominio). Tras cambiarla, regenera mensajes en el admin.
#INVITE_PUBLIC_BASE_URL=https://tu-dominio-publico.com
ACCESS_LINK_TTL_HOURS=8760

# --- Resend ---
RESEND_API_KEY=
RESEND_FROM=noreply@tudominio.com
ORG_EMAIL=organizador@email.com

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO_ORG=
# Pausa entre mensajes en envío masivo (ms). 0 = sin pausa.
TWILIO_SEND_DELAY_MS=450
